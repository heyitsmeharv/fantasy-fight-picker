{
  "name": "fantasy-fight-picker",
  "description": "FFP is a prediction app built with React and AWS where users create an account, browse upcoming fight cards, research fighters, make picks before lock, and earn points based on prediction accuracy.",
  "version": "0.0.3",
  "author": "Adam Harvey",
  "type": "module",
  "scripts": {
    "tf:prereqs": "bash infra/scripts/prereqs.sh",
    "tf:whoami": "bash infra/scripts/whoami.sh",
    "tf:bootstrap": "bash infra/scripts/bootstrap-state.sh",
    "tf:fmt": "bash infra/scripts/fmt.sh",
    "tf:validate": "bash infra/scripts/validate.sh",
    "tf:plan": "bash infra/scripts/plan.sh",
    "tf:apply": "bash infra/scripts/apply.sh",
    "prepare": "husky",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "commit-and-tag-version": "^12.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,tf}": [
      "prettier --write"
    ]
  }
}
